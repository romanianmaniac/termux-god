#!/usr/bin/env bash
#
# termux-god — a convenient Termux wrapper around iso2god-bin (iso2god-rs).
# Converts an Xbox 360 ISO into the GOD format and writes it to /sdcard/termux-god.
#
set -uo pipefail

BIN="${ISO2GOD_BIN:-iso2god-bin}"
DEFAULT_OUT="/sdcard/termux-god"

# ---------- output helpers ---------------------------------------------------
c_info='\033[1;36m'; c_ok='\033[1;32m'; c_err='\033[1;31m'; c_dim='\033[2m'; c_off='\033[0m'
info()  { printf "${c_info}▸${c_off} %s\n" "$*"; }
ok()    { printf "${c_ok}✓${c_off} %s\n" "$*"; }
die()   { printf "${c_err}✗${c_off} %s\n" "$*" >&2; exit 1; }

usage() {
    cat <<EOF
termux-god — Xbox 360 ISO → GOD converter for Termux

Usage:
  termux-god <game.iso> [options]

Options:
  --trim              trim unused tail off the ISO (smaller output)
  --out DIR           output directory (default: $DEFAULT_OUT)
  --threads N         worker threads (default: number of CPU cores)
  --no-progress       do not draw the progress bar
  -h, --help          this help

Output: <out>/<TitleID>/00007000/<MediaID> (+ <MediaID>.data/Data0000…)
Copy the resulting <TitleID> folder to Content/0000000000000000/ on the console drive.
EOF
}

# ---------- argument parsing -------------------------------------------------
ISO=""
OUT="$DEFAULT_OUT"
TRIM=0
THREADS=""
PROGRESS=1

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)     usage; exit 0 ;;
        --trim)        TRIM=1; shift ;;
        --no-progress) PROGRESS=0; shift ;;
        --out)         OUT="${2:-}"; [ -n "$OUT" ] || die "--out requires a path"; shift 2 ;;
        --threads)     THREADS="${2:-}"; [ -n "$THREADS" ] || die "--threads requires a number"; shift 2 ;;
        --)            shift ;;
        -*)            die "Unknown option: $1 (see --help)" ;;
        *)             [ -z "$ISO" ] || die "Unexpected argument: $1"; ISO="$1"; shift ;;
    esac
done

[ -n "$ISO" ] || { usage; exit 1; }
command -v "$BIN" >/dev/null 2>&1 || die "$BIN not found. Run install.sh first."
[ -f "$ISO" ] || die "File not found: $ISO"

# ---------- storage-access check --------------------------------------------
case "$OUT" in
    /sdcard/*|/storage/*)
        if [ ! -d /sdcard ] && [ ! -d "$HOME/storage" ]; then
            die "No shared-storage access. Run once:  termux-setup-storage"
        fi
        ;;
esac
mkdir -p "$OUT" 2>/dev/null || die "Cannot create directory: $OUT"

# ---------- utilities --------------------------------------------------------
human() {
    awk -v b="${1:-0}" 'BEGIN{
        split("B KB MB GB TB", u, " "); s=b; i=1;
        while (s>=1024 && i<5){ s/=1024; i++ }
        if (i==1) printf "%d %s", s, u[i]; else printf "%.1f %s", s, u[i]
    }'
}

dir_bytes() {  # total size of Data* files inside directory $1
    find "$1" -type f -name 'Data*' -printf '%s\n' 2>/dev/null \
        | awk '{s+=$1} END{print s+0}'
}

draw_bar() {  # $1 = bytes written, $2 = total bytes
    local cur="$1" total="$2" width=28 pct=0 filled i bar=''
    if [ "$total" -gt 0 ] 2>/dev/null; then pct=$(( cur * 100 / total )); fi
    [ "$pct" -gt 99 ] && pct=99          # only hit 100% when actually finished
    filled=$(( pct * width / 100 ))
    for ((i=0; i<width; i++)); do
        if [ "$i" -lt "$filled" ]; then bar+='#'; else bar+='-'; fi
    done
    printf "\r  [%s] %3d%%  %s / %s   " "$bar" "$pct" "$(human "$cur")" "$(human "$total")"
}

# ---------- title info (dry-run) --------------------------------------------
info "Reading ISO metadata…"
DRY="$("$BIN" --dry-run "$ISO" "$OUT" 2>&1)" \
    || die "Could not read ISO:"$'\n'"$DRY"

TITLE_ID="$(printf '%s\n' "$DRY" | sed -n 's/^Title ID:[[:space:]]*//p'      | head -n1)"
NAME="$(    printf '%s\n' "$DRY" | sed -n 's/^[[:space:]]*Name:[[:space:]]*//p' | head -n1)"
TYPE="$(    printf '%s\n' "$DRY" | sed -n 's/^[[:space:]]*Type:[[:space:]]*//p' | head -n1)"
[ -n "$TITLE_ID" ] || die "Could not determine Title ID:"$'\n'"$DRY"

printf "  ${c_dim}Title ID:${c_off} %s\n" "$TITLE_ID"
printf "  ${c_dim}Name:    ${c_off} %s\n" "${NAME:-(unknown)}"
printf "  ${c_dim}Type:    ${c_off} %s\n" "${TYPE:-?}"

# ---------- convert into an isolated temporary directory ---------------------
RUNDIR="$OUT/.run.$$"
LOG="$RUNDIR/.iso2god.log"
SUCCESS=0
mkdir -p "$RUNDIR"

cleanup() {
    [ "$SUCCESS" -eq 1 ] && return
    # kill the background worker if alive, and remove the partial output
    [ -n "${WORKER:-}" ] && kill "$WORKER" 2>/dev/null
    rm -rf "$RUNDIR" 2>/dev/null
}
trap cleanup EXIT INT TERM

# assemble binary arguments
args=()
[ "$TRIM" -eq 1 ] && args+=(--trim)
[ -n "$THREADS" ] && args+=(-j "$THREADS")
# default to all cores (upstream default = 1)
if [ -z "$THREADS" ]; then
    NPROC="$(nproc 2>/dev/null || echo 1)"
    args+=(-j "$NPROC")
fi

info "Converting → GOD…"
TOTAL="$(stat -c %s "$ISO" 2>/dev/null || echo 0)"

"$BIN" "${args[@]}" "$ISO" "$RUNDIR" >"$LOG" 2>&1 &
WORKER=$!

if [ "$PROGRESS" -eq 1 ]; then
    while kill -0 "$WORKER" 2>/dev/null; do
        draw_bar "$(dir_bytes "$RUNDIR")" "$TOTAL"
        sleep 0.5
    done
fi

rc=0
wait "$WORKER" || rc=$?

if [ "$PROGRESS" -eq 1 ]; then
    # final bar line at 100%
    printf "\r  [%s] 100%%  done%*s\n" "$(printf '#%.0s' $(seq 1 28))" 20 ""
fi

if [ "$rc" -ne 0 ]; then
    printf '%s\n' "$c_err--- iso2god log ---$c_off" >&2
    tail -n 20 "$LOG" >&2 2>/dev/null
    die "Conversion failed (exit code $rc)."
fi

# ---------- move the result to its final location ---------------------------
TITLEDIR="$(find "$RUNDIR" -mindepth 1 -maxdepth 1 -type d ! -name '.*' | head -n1)"
[ -n "$TITLEDIR" ] || die "No conversion result found in $RUNDIR (see $LOG)"
TID="$(basename "$TITLEDIR")"
FINAL="$OUT/$TID"

[ -e "$FINAL" ] && { info "Overwriting existing $FINAL"; rm -rf "$FINAL"; }
mv "$TITLEDIR" "$OUT/"

SUCCESS=1
rm -rf "$RUNDIR"

ok "Done: $FINAL"
printf "  ${c_dim}Copy the %s folder to Content/0000000000000000/ on the console drive.${c_off}\n" "$TID"
